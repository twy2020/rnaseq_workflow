# Copy this file to docker/proxy.env and edit it if your Docker build needs a proxy.
#
# Important on Docker Desktop:
# - 127.0.0.1 inside a container is the container itself.
# - Use host.docker.internal to reach a proxy running on the host.

HTTP_PROXY=http://host.docker.internal:10808
HTTPS_PROXY=http://host.docker.internal:10808
NO_PROXY=localhost,127.0.0.1,host.docker.internal

# Optional mirrors.
APT_MIRROR=
PIP_INDEX_URL=

# Examples:
# APT_MIRROR=http://mirrors.tuna.tsinghua.edu.cn/ubuntu/
# PIP_INDEX_URL=https://pypi.tuna.tsinghua.edu.cn/simple
